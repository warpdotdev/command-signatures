{
    "name": "awk",
    "description": "Pattern scanning and text processing language",
    "args": [
        {
            "name": "program",
            "description": "AWK program text"
        },
        {
            "name": "file",
            "template": "filepaths",
            "isOptional": true,
            "isVariadic": true
        }
    ],
    "options": [
        {
            "name": "-F",
            "description": "Define the input field separator",
            "args": {
                "name": "fs",
                "description": "Field separator string"
            }
        },
        {
            "name": "-f",
            "description": "Read the AWK program source from the specified file instead of the command line",
            "args": {
                "name": "progfile",
                "template": "filepaths"
            }
        },
        {
            "name": "-v",
            "description": "Assign a value to a variable before execution of the program",
            "args": {
                "name": "var=value",
                "description": "Variable assignment (format: var=value)"
            }
        }
    ]
}
