        },
        {
            "name": "-SIGTTIN",
            "description": "Send TTIN instead of TERM"
        },
        {
            "name": "-SIGTTOU",
            "description": "Send TTOU instead of TERM"
        },
        {
            "name": "-SIGIO",
            "description": "Send IO instead of TERM"
        },
        {
            "name": "-SIGXCPU",
            "description": "Send XCPU instead of TERM"
        },
        {
            "name": "-SIGXFSZ",
            "description": "Send XFSZ instead of TERM"
