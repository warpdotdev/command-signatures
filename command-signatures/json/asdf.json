                    "postProcess": "_NuFrRa_i=>i.split(`\n`).map(e=>a({name:`${e}`,description:\"Shim name\",priority:76,icon:\"fig://icon?type=command\"},n))"
                }
            }
        },
        {
            "name": "update",
            "description": "Update ASDF to the latest stable release (unless --head)",
            "options": [
                {
                    "name": "--head",
                    "description": "Using HEAD commit",
                    "isDangerous": true
                }
            ]
        },
        {
            "name": "version",
            "description": "Version for asdf"
