        {
            "name": [
                "dev",
                "d"
            ],
            "description": "Start a development server",
            "icon": "https://raw.githubusercontent.com/blitz-js/art/master/square-logo-600.png",
            "options": [
                {
                    "name": [
                        "--help",
                        "-h"
                    ],
                    "description": "Show help for command",
                    "priority": 1
                },
                {
                    "name": [
                        "-p",
                        "--port"
                    ],
                    "description": "Set port number",
                    "args": {
                        "name": "port"
                    }
                },
