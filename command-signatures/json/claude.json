        {
            "name": "mcp",
            "description": "Configure and manage MCP servers",
            "options": [
                {
                    "name": [
                        "-h",
                        "--help"
                    ],
                    "description": "Display help for command"
                }
            ],
            "subcommands": [
                {
                    "name": "add",
