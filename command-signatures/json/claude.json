                            }
                        },
                        {
                            "name": "--client-secret",
                            "description": "Prompt for OAuth client secret (or set MCP_CLIENT_SECRET env var)"
                        },
                        {
                            "name": [
                                "-h",
                                "--help"
                            ],
                            "description": "Display help for command"
