{
    "name": "claude",
    "description": "Claude Code - AI coding agent for the terminal",
    "args": {
        "name": "prompt",
        "description": "Your prompt",
        "isOptional": true
    },
    "options": [
        {
            "name": [
                "-h",
                "--help"
            ],
            "description": "Display help for command"
        },
        {
            "name": [
                "-v",
                "--version"
            ],
            "description": "Output the version number"
        },
        {
            "name": [
                "-p",
                "--print"
            ],
            "description": "Print response and exit (useful for pipes)"
        },
        {
            "name": [
                "-c",
                "--continue"
            ],
            "description": "Continue the most recent conversation"
        },
        {
            "name": [
                "-r",
                "--resume"
            ],
            "description": "Resume a conversation by session ID, or open interactive picker with optional search term",
            "args": {
                "name": "value",
                "isOptional": true
            }
        },
        {
            "name": "--fork-session",
            "description": "Create a new session ID when resuming (use with --resume or --continue)"
        },
        {
            "name": [
                "-d",
                "--debug"
            ],
            "description": "Enable debug mode with optional category filtering (e.g., \"api,hooks\")",
            "args": {
                "name": "filter",
                "isOptional": true
            }
        },
        {
            "name": "--debug-file",
            "description": "Write debug logs to a specific file path (implicitly enables debug mode)",
            "args": {
                "name": "path",
                "template": "filepaths"
            }
        },
        {
            "name": "--model",
            "description": "Model for the current session (e.g., \"sonnet\", \"opus\", \"claude-sonnet-4-6\")",
            "args": {
                "name": "model"
            }
        },
        {
            "name": "--agent",
            "description": "Agent for the current session",
            "args": {
                "name": "agent"
            }
        },
        {
            "name": "--agents",
            "description": "JSON object defining custom agents",
            "args": {
                "name": "json"
            }
        },
        {
            "name": "--system-prompt",
            "description": "System prompt to use for the session",
            "args": {
                "name": "prompt"
            }
        },
        {
            "name": "--append-system-prompt",
            "description": "Append a system prompt to the default system prompt",
            "args": {
                "name": "prompt"
            }
        },
        {
            "name": "--tools",
            "description": "Specify the list of available tools (e.g., \"Bash,Edit,Read\")",
            "isRepeatable": true,
            "args": {
                "name": "tools"
            }
        },
        {
            "name": [
                "--allowedTools",
                "--allowed-tools"
            ],
            "description": "Comma or space-separated list of tool names to allow (e.g., \"Bash(git:*) Edit\")",
            "isRepeatable": true,
            "args": {
                "name": "tools"
            }
        },
        {
            "name": [
                "--disallowedTools",
                "--disallowed-tools"
            ],
            "description": "Comma or space-separated list of tool names to deny",
            "isRepeatable": true,
            "args": {
                "name": "tools"
            }
        },
        {
            "name": "--dangerously-skip-permissions",
            "description": "Bypass all permission checks (recommended only for sandboxes with no internet access)"
        },
        {
            "name": "--allow-dangerously-skip-permissions",
            "description": "Enable bypassing all permission checks as an option, without it being enabled by default"
        },
        {
            "name": "--permission-mode",
            "description": "Permission mode to use for the session",
            "args": {
                "name": "mode",
                "suggestions": [
                    "acceptEdits",
                    "auto",
                    "bypassPermissions",
                    "default",
                    "dontAsk",
                    "plan"
                ]
            }
        },
        {
            "name": "--add-dir",
            "description": "Additional directories to allow tool access to",
            "isRepeatable": true,
            "args": {
                "name": "directories",
                "template": "folders"
            }
        },
        {
            "name": "--mcp-config",
            "description": "Load MCP servers from JSON files or strings (space-separated)",
            "isRepeatable": true,
            "args": {
                "name": "configs",
                "template": "filepaths"
            }
        },
        {
            "name": "--strict-mcp-config",
            "description": "Only use MCP servers from --mcp-config, ignoring all other MCP configurations"
        },
        {
            "name": "--chrome",
            "description": "Enable Claude in Chrome integration"
        },
        {
            "name": "--no-chrome",
            "description": "Disable Claude in Chrome integration"
        },
        {
            "name": "--ide",
            "description": "Automatically connect to IDE on startup if exactly one valid IDE is available"
        },
        {
            "name": "--output-format",
            "description": "Output format (only works with --print)",
            "args": {
                "name": "format",
                "suggestions": [
                    "text",
                    "json",
                    "stream-json"
                ]
            }
        },
        {
            "name": "--input-format",
            "description": "Input format (only works with --print)",
            "args": {
                "name": "format",
                "suggestions": [
                    "text",
                    "stream-json"
                ]
            }
        },
        {
            "name": "--include-partial-messages",
            "description": "Include partial message chunks (only works with --print and --output-format=stream-json)"
        },
        {
            "name": "--replay-user-messages",
            "description": "Re-emit user messages on stdout (only works with --input-format=stream-json and --output-format=stream-json)"
        },
        {
            "name": "--include-hook-events",
            "description": "Include all hook lifecycle events in the output stream (only works with --output-format=stream-json)"
        },
        {
            "name": "--session-id",
            "description": "Use a specific session ID for the conversation (must be a valid UUID)",
            "args": {
                "name": "uuid"
            }
        },
        {
            "name": "--no-session-persistence",
            "description": "Disable session persistence (only works with --print)"
        },
        {
            "name": "--settings",
            "description": "Path to a settings JSON file or a JSON string to load additional settings from",
            "args": {
                "name": "file-or-json",
                "template": "filepaths"
            }
        },
        {
            "name": "--setting-sources",
            "description": "Comma-separated list of setting sources to load (user, project, local)",
            "args": {
                "name": "sources"
            }
        },
        {
            "name": "--disable-slash-commands",
            "description": "Disable all skills"
        },
        {
            "name": "--plugin-dir",
            "description": "Load plugins from a directory for this session only",
            "isRepeatable": true,
            "args": {
                "name": "path",
                "template": "folders"
            }
        },
        {
            "name": "--betas",
            "description": "Beta headers to include in API requests (API key users only)",
            "isRepeatable": true,
            "args": {
                "name": "betas"
            }
        },
        {
            "name": "--max-budget-usd",
            "description": "Maximum dollar amount to spend on API calls (only works with --print)",
            "args": {
                "name": "amount"
            }
        },
        {
            "name": "--fallback-model",
            "description": "Enable automatic fallback to specified model when default is overloaded (only works with --print)",
            "args": {
                "name": "model"
            }
        },
        {
            "name": "--json-schema",
            "description": "JSON Schema for structured output validation",
            "args": {
                "name": "schema"
            }
        },
        {
            "name": "--file",
            "description": "File resources to download at startup (format: file_id:relative_path)",
            "isRepeatable": true,
            "args": {
                "name": "specs"
            }
        },
        {
            "name": "--verbose",
            "description": "Override verbose mode setting from config"
        },
        {
            "name": [
                "-n",
                "--name"
            ],
            "description": "Set a display name for this session",
            "args": {
                "name": "name"
            }
        },
        {
            "name": "--bare",
            "description": "Minimal mode: skip hooks, LSP, plugin sync, attribution, auto-memory, and more"
        },
        {
            "name": "--brief",
            "description": "Enable SendUserMessage tool for agent-to-user communication"
        },
        {
            "name": "--effort",
            "description": "Effort level for the current session",
            "args": {
                "name": "level",
                "suggestions": [
                    "low",
                    "medium",
                    "high",
                    "max"
                ]
            }
        },
        {
            "name": "--from-pr",
            "description": "Resume a session linked to a PR by PR number/URL, or open interactive picker",
            "args": {
                "name": "value",
                "isOptional": true
            }
        },
        {
            "name": "--remote-control-session-name-prefix",
            "description": "Prefix for auto-generated Remote Control session names",
            "args": {
                "name": "prefix"
            }
        },
        {
            "name": "--tmux",
            "description": "Create a tmux session for the worktree (requires --worktree)"
        },
        {
            "name": [
                "-w",
                "--worktree"
            ],
            "description": "Create a new git worktree for this session (optionally specify a name)",
            "args": {
                "name": "name",
                "isOptional": true
            }
        }
    ],
    "subcommands": [
