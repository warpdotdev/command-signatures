                        {
                            "name": "args",
                            "description": "Additional arguments",
                            "isOptional": true,
                            "isVariadic": true
                        }
                    ],
                    "options": [
                        {
                            "name": [
                                "-t",
                                "--transport"
                            ],
                            "description": "Transport type (defaults to stdio if not specified)",
                            "args": {
                                "name": "transport",
