        {
            "name": "apply_dump",
            "description": "Accepts a filename containing `direnv dump` output and generates a series of bash export statements to apply the given env",
            "priority": 49,
            "args": {
                "name": "FILE",
                "template": "filepaths",
                "isDangerous": true
            }
        },
