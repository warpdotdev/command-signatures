{
    "name": "wrangler",
    "description": "Wrangler CLI for Cloudflare Workers",
    "subcommands": [
        {
            "name": "generate",
            "args": [
                {
                    "name": "name",
                    "isOptional": true,
                    "description": "The name of your worker! [default: worker]"
                },
                {
                    "name": "template",
                    "isOptional": true,
                    "description": "A link to a GitHub template! Defaults to \nhttps://github.com/cloudflare/worker-template"
                }
            ],
            "options": [
                {
                    "name": [
                        "-c",
                        "--config"
                    ],
                    "args": {
                        "name": "wrangler.toml",
                        "template": "filepaths"
                    },
                    "description": "Path to configuration file [default: wrangler.toml]"
                },
                {
                    "name": [
                        "-e",
                        "--env"
                    ],
                    "args": {
                        "name": "environment"
                    },
                    "description": "Environment to perform a command on"
                },
                {
                    "name": [
                        "-h",
                        "--help"
                    ],
                    "description": "Prints help information"
                },
                {
                    "name": "--verbose",
                    "description": "Toggle verbose output (when applicable)"
                },
                {
                    "name": [
                        "-s",
                        "--site"
                    ],
                    "args": {
                        "name": "site",
                        "isOptional": true
                    },
                    "description": "Initializes a Workers Sites project. Overrides 'type' \nand 'template'"
                },
                {
                    "name": [
                        "-t",
                        "--type"
                    ],
                    "args": {
                        "name": "type",
                        "isOptional": true
                    },
                    "description": "The type of project you want generated"
                }
            ],
            "description": "Generate a new worker project"
        },
