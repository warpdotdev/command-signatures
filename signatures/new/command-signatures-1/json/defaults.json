{
    "name": "defaults",
    "description": "Command line interface to a user's defaults",
    "subcommands": [
        {
            "name": "read",
            "description": "Shows defaults",
            "args": [
                {
                    "name": "domain",
                    "generatorName": "domain_generator",
                    "suggestions": [
                        {
                            "name": "-globalDomain",
                            "description": "Global domain"
                        },
                        {
                            "name": "-app",
                            "insertValue": "-app '{cursor}'",
                            "description": "Application name"
                        }
                    ]
                },
                {
                    "name": "key"
                }
            ]
        },
        {
            "name": "write",
            "description": "Writes key for domain",
            "args": [
                {
                    "name": "domain",
                    "generatorName": "domain_generator",
                    "suggestions": [
                        {
                            "name": "-globalDomain",
                            "description": "Global domain"
                        },
                        {
                            "name": "-app",
                            "insertValue": "-app '{cursor}'",
                            "description": "Application name"
                        }
                    ]
                },
                {
                    "name": "key"
                },
                {
                    "name": "value"
                }
            ]
        },
        {
            "name": "delete",
            "description": "Deletes domain or key in domain",
            "args": [
                {
                    "name": "domain",
                    "generatorName": "domain_generator",
                    "suggestions": [
                        {
                            "name": "-globalDomain",
                            "description": "Global domain"
                        },
                        {
                            "name": "-app",
                            "insertValue": "-app '{cursor}'",
                            "description": "Application name"
                        }
                    ]
                },
