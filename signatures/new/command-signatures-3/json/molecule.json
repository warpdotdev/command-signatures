                            "vagrant",
                            "azure",
                            "hetzner"
                        ]
                    }
                },
                {
                    "name": "--all",
                    "description": "Destroy all scenarios. Default is False",
                    "exclusiveOn": [
                        "--no-all"
                    ]
                },
                {
                    "name": "--no-all",
                    "description": "Do not destroy all scenarios",
                    "exclusiveOn": [
                        "--all"
                    ]
                },
                {
                    "name": "--parallel",
                    "description": "Enable parallel mode",
                    "exclusiveOn": [
                        "--no-parallel"
                    ]
                },
                {
                    "name": "--no-parallel",
                    "description": "Disable parallel mode",
                    "exclusiveOn": [
                        "--parallel"
                    ]
