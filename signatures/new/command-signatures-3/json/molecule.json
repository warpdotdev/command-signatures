                            "args": {
                                "name": "TEXT",
                                "suggestions": [
                                    "ansible",
                                    "testinfra"
                                ]
                            }
                        }
                    ],
                    "args": {
                        "name": "ROLE_NAME"
                    },
                    "parserDirectives": {
                        "optionsMustPrecedeArguments": true
                    }
