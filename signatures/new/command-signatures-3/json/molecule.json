                    "name": [
                        "--scenario-name",
                        "-s"
                    ],
                    "description": "Name of the scenario to target. (default)",
                    "args": {
                        "name": "TEXT"
                    }
                },
                {
                    "name": [
                        "--driver-name",
                        "-d"
                    ],
                    "description": "Name of driver to use. (delegated)",
                    "args": {
                        "name": "TEXT",
                        "suggestions": [
                            "delegated",
                            "docker",
                            "podman",
                            "vagrant",
                            "azure",
                            "hetzner"
                        ]
                    }
                }
            ]
        },
        {
            "name": "dependency",
            "description": "Manage the role's dependencies",
            "options": [
                {
                    "name": [
                        "--scenario-name",
                        "-s"
                    ],
                    "description": "Name of the scenario to target. (default)",
                    "args": {
                        "name": "TEXT"
                    }
                }
            ]
        },
        {
            "name": "destroy",
            "description": "Use the provisioner to destroy the instances",
            "options": [
                {
                    "name": [
                        "--scenario-name",
                        "-s"
                    ],
                    "description": "Name of the scenario to target. (default)",
                    "args": {
                        "name": "TEXT"
                    }
                },
                {
                    "name": [
                        "--driver-name",
