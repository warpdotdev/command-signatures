{
    "name": "ln",
    "description": "Create (default hard) symbolic links to files",
    "args": [
        {
            "name": "source_file",
            "template": [
                "filepaths",
                "folders"
            ]
        },
        {
            "name": "link_name or link_dirname",
            "isOptional": true
        }
    ],
    "options": [
        {
            "name": "-s",
            "description": "Create a symbolic link",
            "args": [
                {
                    "name": "source_file",
                    "template": [
                        "filepaths",
                        "folders"
                    ]
                },
                {
                    "name": "link_name or link_dirname",
                    "isOptional": true
                }
            ]
        },
        {
            "name": "-v",
            "description": "Verbose"
        },
        {
            "name": "-F",
            "description": "If link name already exists replace it",
            "args": [
                {
                    "name": "source_file",
                    "template": [
                        "filepaths",
                        "folders"
                    ]
                },
                {
                    "name": "link_name or link_dirname",
                    "isOptional": true
                }
            ]
        },
        {
            "name": "-h",
            "description": "Don't follow symbolic links"
        },
        {
            "name": "-f",
            "description": "If link name already exists unlink the old one before creating the new one",
            "args": [
                {
                    "name": "source_file",
                    "template": [
                        "filepaths",
                        "folders"
                    ]
                },
                {
                    "name": "link_name or link_dirname",
                    "isOptional": true
                }
            ]
        },
        {
            "name": "-i",
            "description": "Prompt if proposed link already exists",
            "args": [
                {
                    "name": "source_file",
                    "template": [
                        "filepaths",
                        "folders"
                    ]
                },
                {
                    "name": "link_name or link_dirname",
                    "isOptional": true
                }
            ]
        },
        {
            "name": "-n",
            "description": "Same as -h don't follow symbolic links"
        }
    ]
}