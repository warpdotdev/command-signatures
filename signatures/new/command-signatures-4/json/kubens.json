{
    "name": "kubens",
    "description": "Switch between Kubernetes-namespaces",
    "additionalSuggestions": [
        {
            "name": "-",
            "priority": 85,
            "description": "Switch to previous namespace within the current context",
            "icon": "fig://icon?type=asterisk"
        }
    ],
    "parserDirectives": {
        "flagsArePosixNoncompliant": true
    },
    "options": [
        {
            "name": [
                "--help",
                "-h"
            ],
            "description": "Show help for kubens"
        },
        {
            "name": [
                "--current",
                "-c"
            ],
            "description": "Show current namespace"
        }
    ],
    "args": {
        "name": "namespace",
        "generators": [
            {
                "script": "kubens | grep -v $(kubens -c)",
                "postProcess": "_NuFrRa_e=>e.split(`\n`).map(n=>({name:n,priority:90,icon:\"fig://icon?type=kubernetes\"}))"
            },
            {
                "script": "kubens -c",
                "postProcess": "_NuFrRa_e=>e?[{name:e,priority:100,icon:\"\\u2B50\\uFE0F\"}]:[]"
            }
        ],
        "isOptional": true
    }
}