{
  "name": "kubens",
  "description": "Switch between Kubernetes-namespaces",
  "additionalSuggestions": [
    {
      "name": "-",
      "priority": 85,
      "description": "Switch to previous namespace within the current context",
      "icon": "fig://icon?type=asterisk"
    }
  ],
  "parserDirectives": { "flagsArePosixNoncompliant": true },
  "options": [
    { "name": ["--help", "-h"], "description": "Show help for kubens" },
    { "name": ["--current", "-c"], "description": "Show current namespace" }
  ],
  "args": {
    "name": "namespace",
    "generators": [
      {
        "script": "kubens | grep -v $(kubens -c)",
        "postProcess": "_NuFrRa_e => e.split(\"\\n\").map(n => ({\n        name: n,\n        priority: 90,\n        icon: \"fig://icon?type=kubernetes\"\n      }))"
      },
      {
        "script": "kubens -c",
        "postProcess": "_NuFrRa_e => e ? [{\n        name: e,\n        priority: 100,\n        icon: \"\\u2B50\\uFE0F\"\n      }] : []"
      }
    ],
    "isOptional": true
  }
}
