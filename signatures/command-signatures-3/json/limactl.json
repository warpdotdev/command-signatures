{
  "name": "limactl",
  "description": "Control the Lima(Linux virtual machines)",
  "subcommands": [
    {
      "name": "completion",
      "description": "Generate the autocompletion script for the specified shell",
      "subcommands": [
        {
          "name": "bash",
          "description": "Generate the autocompletion script for bash",
          "options": [
            { "name": ["-h", "--help"], "description": "Help for bash" },
            { "name": "--debug", "description": "Debug mode" },
            {
              "name": "--no-descriptions",
              "description": "Disable completion descriptions"
            }
          ]
        },
        {
          "name": "fish",
          "description": "Generate the autocompletion script for fish",
          "options": [
            { "name": ["-h", "--help"], "description": "Help for fish" },
            { "name": "--debug", "description": "Debug mode" },
            {
              "name": "--no-descriptions",
              "description": "Disable completion descriptions"
            }
          ]
        },
        {
          "name": "powershell",
          "description": "Generate the autocompletion script for powershell",
          "options": [
            { "name": ["-h", "--help"], "description": "Help for powershell" },
            { "name": "--debug", "description": "Debug mode" },
            {
              "name": "--no-descriptions",
              "description": "Disable completion descriptions"
            }
          ]
        },
        {
          "name": "zsh",
          "description": "Generate the autocompletion script for zsh",
          "options": [
            { "name": ["-h", "--help"], "description": "Help for zsh" },
            { "name": "--debug", "description": "Debug mode" },
            {
              "name": "--no-descriptions",
              "description": "Disable completion descriptions"
            }
          ]
        }
      ],
      "options": [
        { "name": ["-h", "--help"], "description": "Help for completion" },
        { "name": "--debug", "description": "Debug mode" }
      ]
    },
    {
      "name": ["copy", "cp"],
      "description": "Copy files between host and guest",
      "args": [
        {
          "name": "SOURCE",
          "isVariadic": true,
          "generators": [
            {
              "script": "limactl list --quiet",
              "postProcess": "_NuFrRa_o => o.split(\"\\n\").map(s => _objectSpread({\n    name: \"\".concat(s),\n    description: \"Instance name\",\n    priority: r\n  }, t))"
            },
            { "template": "filepaths" }
          ]
        },
        {
          "name": "TARGET",
          "generators": [
            {
              "script": "limactl list --quiet",
              "postProcess": "_NuFrRa_o => o.split(\"\\n\").map(s => _objectSpread({\n    name: \"\".concat(s),\n    description: \"Instance name\",\n    priority: r\n  }, t))"
            },
            { "template": "filepaths" }
          ]
        }
      ],
      "options": [
        { "name": ["-h", "--help"], "description": "Help for copy" },
        { "name": "--debug", "description": "Debug mode" },
        {
          "name": ["-r", "--recursive"],
          "description": "Copy directories recursively"
        }
      ]
    },
    {
      "name": ["delete", "remove", "rm"],
      "description": "Delete an instance of Lima",
      "args": {
        "name": "INSTANCE",
        "isVariadic": true,
        "generators": {
          "script": "limactl list --quiet",
          "postProcess": "_NuFrRa_o => o.split(\"\\n\").map(s => _objectSpread({\n    name: \"\".concat(s),\n    description: \"Instance name\",\n    priority: r\n  }, t))"
        }
      },
      "options": [
        { "name": ["-h", "--help"], "description": "Help for delete" },
        { "name": "--debug", "description": "Debug mode" },
        {
          "name": ["-f", "--force"],
          "description": "Forcibly kill the processes",
          "isDangerous": true
        }
      ]
    },
    {
      "name": "info",
      "description": "Show diagnostic information",
      "options": [
        { "name": ["-h", "--help"], "description": "Help for info" },
        { "name": "--debug", "description": "Debug mode" }
      ]
    },
    {
      "name": ["list", "ls"],
      "description": "List instances of Lima",
      "options": [
        { "name": ["-h", "--help"], "description": "Help for list" },
        { "name": "--debug", "description": "Debug mode" },
        { "name": "--json", "description": "JSONify output" },
        { "name": ["-q", "--quiet"], "description": "Only show names" }
      ]
    },
    {
      "name": "prune",
      "description": "Prune garbage objects",
      "isDangerous": true,
      "options": [
        { "name": ["-h", "--help"], "description": "Help for prune" },
        { "name": "--debug", "description": "Debug mode" }
      ]
    },
    {
      "name": "shell",
      "description": "Lima command is provided as an alias for limactl shell $LIMA_INSTANCE. $LIMA_INSTANCE defaults to \"default\"",
      "args": [
        {
          "name": "INSTANCE",
          "generators": {
            "script": "limactl list --quiet",
            "postProcess": "_NuFrRa_o => o.split(\"\\n\").map(s => _objectSpread({\n    name: \"\".concat(s),\n    description: \"Instance name\",\n    priority: r\n  }, t))"
          }
        },
        {
          "name": "COMMAND",
          "isVariadic": true,
          "isOptional": true,
          "isCommand": true
        }
      ],
      "options": [
        { "name": ["-h", "--help"], "description": "Help for shell" },
        { "name": "--debug", "description": "Debug mode" },
        {
          "name": "--workdir",
          "description": "Working directory",
          "args": { "name": "string" }
        }
      ]
    },
    {
      "name": "show-ssh",
      "description": "Show the ssh command line",
      "args": {
        "name": "INSTANCE",
        "generators": {
          "script": "limactl list --quiet",
          "postProcess": "_NuFrRa_o => o.split(\"\\n\").map(s => _objectSpread({\n    name: \"\".concat(s),\n    description: \"Instance name\",\n    priority: r\n  }, t))"
        }
      },
      "options": [
        { "name": ["-h", "--help"], "description": "Help for show-ssh" },
        { "name": "--debug", "description": "Debug mode" },
        {
          "name": ["-f", "--format"],
          "description": "Format: cmd, args, options, config (default \"cmd\")",
          "args": {
            "name": "string",
            "default": "cmd",
            "suggestions": [
              { "name": "cmd", "description": "Full ssh command line" },
              {
                "name": "args",
                "description": "Similar to the cmd format but omits \"ssh\" and the destination address"
              },
              {
                "name": "options",
                "description": "Ssh option key value pairs"
              },
              { "name": "config", "description": "~/.ssh/config format" }
            ]
          }
        }
      ]
    },
    {
      "name": "start",
      "description": "Start an instance of Lima. If the instance does not exist, open an editor for creating new one, with name \"default\"",
      "args": {
        "name": "NAME|FILE.yaml|URL",
        "generators": [
          {
            "script": "limactl list --quiet",
            "postProcess": "_NuFrRa_o => o.split(\"\\n\").map(s => _objectSpread({\n    name: \"\".concat(s),\n    description: \"Instance name\",\n    priority: r\n  }, t))"
          },
          {
            "template": "filepaths",
            "filterTemplateSuggestions": "_NuFrRa_o => {\n    let s = i => i.endsWith(\".yaml\") || i.endsWith(\".yml\");\n\n    return o.filter(i => s(i.name) || i.name.endsWith(\"/\")).map(i => _objectSpread(_objectSpread({}, i), {}, {\n      priority: s(i.name) && r\n    }, t));\n  }"
          }
        ]
      },
      "options": [
        { "name": ["-h", "--help"], "description": "Help for start" },
        { "name": "--debug", "description": "Debug mode" },
        {
          "name": "--tty",
          "description": "Enable TUI interactions such as opening an editor, defaults to true when stdout is a terminal (default true)"
        }
      ]
    },
    {
      "name": "stop",
      "description": "Stop an instance",
      "isDangerous": true,
      "args": {
        "name": "INSTANCE",
        "generators": {
          "script": "limactl list --quiet",
          "postProcess": "_NuFrRa_o => o.split(\"\\n\").map(s => _objectSpread({\n    name: \"\".concat(s),\n    description: \"Instance name\",\n    priority: r\n  }, t))"
        }
      },
      "options": [
        { "name": ["-h", "--help"], "description": "Help for stop" },
        { "name": "--debug", "description": "Debug mode" },
        {
          "name": ["-f", "--force"],
          "description": "Force stop the instance",
          "isDangerous": true
        }
      ]
    },
    {
      "name": "sudoers",
      "description": "Generate /etc/sudoers.d/lima file for enabling vmnet.framework support. See /usr/local/share/doc/lima/docs/network.md for the usage",
      "args": {
        "name": "SUDORSFILE",
        "isOptional": true,
        "template": "filepaths"
      },
      "options": [
        { "name": ["-h", "--help"], "description": "Help for sudoers" },
        { "name": "--debug", "description": "Debug mode" },
        {
          "name": "--check",
          "description": "Check that the sudoers file is up-to-date with \"~/.lima/_config/networks.yaml\""
        }
      ]
    },
    {
      "name": "validate",
      "description": "Validate YAML files",
      "args": {
        "name": "FILE.yaml",
        "isVariadic": true,
        "generators": {
          "template": "filepaths",
          "filterTemplateSuggestions": "_NuFrRa_o => {\n    let s = i => i.endsWith(\".yaml\") || i.endsWith(\".yml\");\n\n    return o.filter(i => s(i.name) || i.name.endsWith(\"/\")).map(i => _objectSpread(_objectSpread({}, i), {}, {\n      priority: s(i.name) && r\n    }, t));\n  }"
        }
      },
      "options": [
        { "name": ["-h", "--help"], "description": "Help for validate" },
        { "name": "--debug", "description": "Debug mode" }
      ]
    },
    {
      "name": "help",
      "description": "Help provides help for any command in the application",
      "args": {
        "name": "command",
        "isOptional": true,
        "suggestions": [
          {
            "name": "completion",
            "description": "Generate the autocompletion script for the specified shell",
            "type": "subcommand"
          },
          {
            "name": ["copy", "cp"],
            "description": "Copy files between host and guest",
            "type": "subcommand"
          },
          {
            "name": ["delete", "remove", "rm"],
            "description": "Delete an instance of Lima",
            "type": "subcommand"
          },
          {
            "name": "info",
            "description": "Show diagnostic information",
            "type": "subcommand"
          },
          {
            "name": ["list", "ls"],
            "description": "List instances of Lima",
            "type": "subcommand"
          },
          {
            "name": "prune",
            "description": "Prune garbage objects",
            "type": "subcommand"
          },
          {
            "name": "shell",
            "description": "Lima command is provided as an alias for limactl shell $LIMA_INSTANCE. $LIMA_INSTANCE defaults to \"default\"",
            "type": "subcommand"
          },
          {
            "name": "show-ssh",
            "description": "Show the ssh command line",
            "type": "subcommand"
          },
          {
            "name": "start",
            "description": "Start an instance of Lima. If the instance does not exist, open an editor for creating new one, with name \"default\"",
            "type": "subcommand"
          },
          {
            "name": "stop",
            "description": "Stop an instance",
            "type": "subcommand"
          },
          {
            "name": "sudoers",
            "description": "Generate /etc/sudoers.d/lima file for enabling vmnet.framework support. See /usr/local/share/doc/lima/docs/network.md for the usage",
            "type": "subcommand"
          },
          {
            "name": "validate",
            "description": "Validate YAML files",
            "type": "subcommand"
          },
          {
            "name": "help",
            "description": "Help provides help for any command in the application",
            "type": "subcommand"
          }
        ]
      }
    }
  ],
  "options": [
    { "name": ["-h", "--help"], "description": "Help for limactl" },
    { "name": "--debug", "description": "Debug mode" },
    { "name": ["-v", "--version"], "description": "Version for limactl" }
  ]
}
